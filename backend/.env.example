# ── 필수 변경 항목 (production 배포 전 반드시 변경) ──────────────────────────
# SECRET_KEY: openssl rand -hex 32  으로 새 키를 생성하세요
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# APP_ENV: production | development
APP_ENV=development

# ── 토큰 / 로그인 보안 ──────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=120
LOGIN_MAX_ATTEMPTS=7
LOGIN_BLOCK_MINUTES=10

# ── CORS (production에서는 실제 https 도메인만 허용) ─────────────────────────
# 예시: CORS_ALLOW_ORIGINS=https://draw.example.com,capacitor://localhost
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,capacitor://localhost,ionic://localhost

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./app.db
