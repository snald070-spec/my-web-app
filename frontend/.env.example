# Optional API base URL override
# Web dev/prod can usually leave this empty.
# Mobile app should set this to a reachable backend URL.
# Example (Android emulator):
# VITE_API_BASE_URL=http://10.0.2.2:8000
# Example (real device on same LAN):
# VITE_API_BASE_URL=http://192.168.0.10:8000
VITE_API_BASE_URL=
